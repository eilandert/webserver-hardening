Description: JA3/JA4 TLS fingerprinting — capture ClientHello in nginx core.
 Adds the SSL_client_hello callback wiring and the fp_* fields on
 ngx_ssl_connection_s so libnginx-mod-ssl-fingerprint can compute JA3/JA4.
 All additions guarded by NGX_SSL_FINGERPRINT (set by the module's config),
 so the patch is inert unless the module is built.
 Rebased onto our patch stack (applies after nginx_dynamic_tls_records,
 which reorders ngx_ssl_connection_s) — verified zero-fuzz with -F0.
Origin: https://github.com/HanadaLee/ngx_ssl_fingerprint_module (patches/nginx-1.29.3+.patch)
Forwarded: not-needed (nginx considers TLS fingerprinting out of scope)
--- a/src/event/ngx_event_openssl.c
+++ b/src/event/ngx_event_openssl.c
@@ -17,6 +17,23 @@
 #define NGX_SSL_PASSWORD_BUFFER_SIZE  4096
 
 
+#if (NGX_SSL_FINGERPRINT)
+
+#define ngx_ssl_fingerprint_is_grease(code)                                   \
+    (((code) & 0x0f0f) == 0x0a0a && ((code) & 0xff) == ((code) >> 8))         \
+
+
+#define ngx_ssl_fingerprint_is_alnum(c)                                       \
+    ((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')                         \
+     || (c >= '0' && c <= '9'))                                               \
+
+
+ngx_uint_t     ngx_ssl_fingerprint_enabled;
+ngx_cycle_t   *ngx_ssl_fingerprint_cycle;
+
+#endif
+
+
 typedef struct {
     ngx_uint_t  engine;   /* unsigned  engine:1; */
 } ngx_openssl_conf_t;
@@ -2198,6 +2215,261 @@
 }
 
 
+#if (NGX_SSL_FINGERPRINT)
+
+static u_char *
+ngx_ssl_fingerprint_append_uint16(u_char *dst, uint16_t val)
+{
+    return ngx_copy(dst, &val, sizeof(uint16_t));
+}
+
+
+static int
+ngx_ssl_client_hello_cb(SSL *s, int *al, void *arg)
+{
+    int                is_sni;
+    u_char            *p;
+    size_t             i, ciphers_len, groups_len, formats_len,
+                       num_exts, versions_len, alpn_len, sig_algos_len;
+    uint8_t            first_alpn_len, first, last;
+    uint16_t           legacy_version, max_version, version, *exts,
+                       exts_len;
+    ngx_str_t         *ja;
+    ngx_connection_t  *c;
+
+    static u_char      hex[] = "0123456789abcdef";
+    const u_char      *ciphers = NULL, *groups = NULL, *formats = NULL,
+                      *versions = NULL, *alpn = NULL, *sig_algos = NULL;
+
+    ciphers_len = 0;
+    groups_len = 0;
+    formats_len = 0;
+    num_exts = 0;
+    versions_len = 0;
+    alpn_len = 0;
+    sig_algos_len = 0;
+
+    is_sni = 0;
+
+    exts = NULL;
+    exts_len = 0;
+
+    c = ngx_ssl_get_connection(s);
+
+    if (c == NULL || c->ssl == NULL) {
+        return SSL_CLIENT_HELLO_SUCCESS;
+    }
+
+    /* get received extensions */
+    SSL_client_hello_get0_received_ext(s, NULL, &num_exts);
+    exts_len = num_exts * sizeof(uint16_t);
+
+    ciphers_len = SSL_client_hello_get0_ciphers(s, &ciphers);
+
+    SSL_client_hello_get0_ext(s, TLSEXT_TYPE_supported_groups, &groups,
+                              &groups_len);
+    SSL_client_hello_get0_ext(s, TLSEXT_TYPE_ec_point_formats, &formats,
+                              &formats_len);
+
+    /* ja3 */
+    ja = &c->ssl->fp_ja3_data;
+    ja->len = sizeof(uint16_t)                                    /* version */
+              + sizeof(uint16_t)                              /* ciphers_len */
+              + ciphers_len                                       /* ciphers */
+              + sizeof(uint16_t)                                 /* exts_len */
+              + exts_len                                       /* extensions */
+              + (groups_len > 0 ? groups_len : sizeof(uint16_t))   /* groups */
+              + (formats_len > 0 ? formats_len : sizeof(uint8_t)); /* formats */
+
+    ja->data = ngx_pnalloc(c->pool, ja->len);
+    if (ja->data == NULL) {
+        ngx_log_error(NGX_LOG_ERR, c->log, 0, "ngx_ssl_client_hello_cb: "
+                      "out of memory for fp_ja3_data");
+        goto failed;
+    }
+
+    p = ja->data;
+
+    /* version */
+    legacy_version = (uint16_t) SSL_client_hello_get0_legacy_version(s);
+    p = ngx_ssl_fingerprint_append_uint16(p, legacy_version);
+
+    /* ciphers */
+    p = ngx_ssl_fingerprint_append_uint16(p, (uint16_t) ciphers_len);
+    p = ngx_copy(p, ciphers, ciphers_len);
+
+    /* extensions */
+    p = ngx_ssl_fingerprint_append_uint16(p, exts_len);
+    exts = (uint16_t *) p;
+
+    if (((uintptr_t) exts) % 2 != 0) {
+        ngx_log_error(NGX_LOG_WARN, c->log, 0, "ngx_ssl_client_hello_cb: "
+                      "ext destination is not 2-byte aligned");
+    }
+
+    SSL_client_hello_get0_received_ext(s, exts, &num_exts);
+    p += exts_len;
+
+    /* groups */
+    if (groups_len > 0) {
+        ngx_memcpy(p, groups, groups_len);
+        *(uint16_t *) p = (uint16_t) groups_len;
+        p += groups_len;
+
+    } else {
+        *(uint16_t *) p = (uint16_t) 0;
+        p += sizeof(uint16_t);
+    }
+
+    /* formats */
+    if (formats_len > 0) {
+        ngx_memcpy(p, formats, formats_len);
+        *(uint8_t *) p = (uint8_t) formats_len;
+        p += formats_len;
+
+    } else {
+        *(uint8_t *) p = (uint8_t) 0;
+        p += sizeof(uint8_t);
+    }
+
+    if (p != ja->data + ja->len) {
+        ngx_log_error(NGX_LOG_ERR, c->log, 0, "ngx_ssl_client_hello_cb: "
+                      "length mismatch for ja3");
+        goto failed;
+    }
+
+    /* ja4 */
+    ja = &c->ssl->fp_ja4_data;
+
+    for (i = 0; i < num_exts; i++) {
+        if (exts[i] == TLSEXT_TYPE_server_name) {
+            is_sni = 1;
+        }
+    }
+
+    SSL_client_hello_get0_ext(s, TLSEXT_TYPE_signature_algorithms, &sig_algos,
+                              &sig_algos_len);
+
+    ja->len = sizeof(char)        /* protocol */
+              + sizeof(char)      /* sni */
+              + sizeof(uint16_t)  /* version */
+              + sizeof(char) * 2  /* first ALPN */
+              + sizeof(uint16_t)  /* ciphers_len */
+              + ciphers_len       /* ciphers */
+              + sizeof(uint16_t)  /* exts_len */
+              + exts_len          /* extensions */
+              + sizeof(uint16_t)  /* sig_algos_len */
+              + sig_algos_len;    /* sig_algos */
+
+    ja->data = ngx_pnalloc(c->pool, ja->len);
+    if (ja->data == NULL) {
+        ngx_log_error(NGX_LOG_ERR, c->log, 0, "ngx_ssl_client_hello_cb: "
+                      "out of memory for fp_ja4_data");
+        goto failed;
+    }
+
+    p = ja->data;
+
+    SSL_client_hello_get0_ext(s, TLSEXT_TYPE_supported_versions, &versions,
+                              &versions_len);
+    SSL_client_hello_get0_ext(s,
+                            TLSEXT_TYPE_application_layer_protocol_negotiation,
+                            &alpn, &alpn_len);
+
+    /* protocol */
+#if (NGX_QUIC)
+    *p++ = (u_char) (c->quic
+                       ? 'q'
+                       : SSL_is_dtls(s) ? 'd' : 't');
+#else
+    *p++ = (u_char) (SSL_is_dtls(s) ? 'd' : 't');
+#endif
+
+    /* sni */
+    *p++ = (u_char) (is_sni ? 'd' : 'i');
+
+    /* version */
+    if (versions_len > 0) {
+        max_version = 0;
+        for (i = 1; i < versions_len; i += 2) {
+            version = (versions[i] << 8) | versions[i + 1];
+            ngx_log_error(NGX_LOG_INFO, c->log, 0,
+                          "ngx_ssl_client_hello_cb: i=%uz, version=%ui",
+                          i, (ngx_uint_t) version);
+            if (!ngx_ssl_fingerprint_is_grease(version)
+                && version > max_version)
+            {
+                max_version = version;
+            }
+        }
+
+        p = ngx_ssl_fingerprint_append_uint16(p, max_version);
+
+    } else {
+        p = ngx_ssl_fingerprint_append_uint16(p, legacy_version);
+    }
+
+    /* first ALPN */
+    if (alpn_len >= 3) {
+        first_alpn_len = alpn[2];
+        if (first_alpn_len == 0 || (size_t) 3 + first_alpn_len > alpn_len) {
+            ngx_log_error(NGX_LOG_ERR, c->log, 0,
+                          "ngx_ssl_client_hello_cb: "
+                          "invalid first_alpn_len=%ui, alpn_len=%uz",
+                          (ngx_uint_t) first_alpn_len, alpn_len);
+            goto failed;
+        }
+
+        first = alpn[3];
+        last = alpn[3 + first_alpn_len - 1];
+
+        if (!ngx_ssl_fingerprint_is_alnum(first)
+            || !ngx_ssl_fingerprint_is_alnum(last))
+        {
+            *p++ = hex[(first >> 4) & 0x0f];
+            *p++ = hex[last & 0x0f];
+
+        } else {
+            *p++ = first;
+            *p++ = last;
+        }
+
+    } else {
+        *p++ = '0';
+        *p++ = '0';
+    }
+
+    /* ciphers */
+    p = ngx_ssl_fingerprint_append_uint16(p, (uint16_t) ciphers_len);
+    p = ngx_copy(p, ciphers, ciphers_len);
+
+    /* extensions */
+    p = ngx_ssl_fingerprint_append_uint16(p, exts_len);
+    p = ngx_copy(p, exts, exts_len);
+
+    /* signature algorithms */
+    p = ngx_ssl_fingerprint_append_uint16(p, (uint16_t) sig_algos_len);
+    p = ngx_copy(p, sig_algos, sig_algos_len);
+
+    if (p != ja->data + ja->len) {
+        ngx_log_error(NGX_LOG_ERR, c->log, 0, "ngx_ssl_client_hello_cb: "
+                      "length mismatch for ja4");
+        goto failed;
+    }
+
+    return SSL_CLIENT_HELLO_SUCCESS;
+
+failed:
+
+    ja->data = NULL;
+    ja->len = 0;
+
+    return SSL_CLIENT_HELLO_SUCCESS;
+}
+
+#endif
+
+
 ngx_int_t
 ngx_ssl_handshake(ngx_connection_t *c)
 {
@@ -2217,6 +2489,13 @@
 
     ngx_ssl_clear_error(c->log);
 
+#if (NGX_SSL_FINGERPRINT)
+    if (ngx_ssl_fingerprint_enabled) {
+        (void) SSL_CTX_set_client_hello_cb(c->ssl->session_ctx,
+                                           ngx_ssl_client_hello_cb, NULL);
+    }
+#endif
+
     n = SSL_do_handshake(c->ssl->connection);
 
     ngx_log_debug1(NGX_LOG_DEBUG_EVENT, c->log, 0, "SSL_do_handshake: %d", n);
--- a/src/event/ngx_event_openssl.h
+++ b/src/event/ngx_event_openssl.h
@@ -162,6 +162,21 @@
     ngx_msec_t                  dyn_rec_last_write;
     ngx_uint_t                  dyn_rec_records_sent;
     unsigned                    sni_accepted:1;
+
+#if (NGX_SSL_FINGERPRINT)
+
+    uint16_t                    fp_greased;
+
+    ngx_str_t                   fp_ja3_data;
+    ngx_str_t                   fp_ja3_str;
+    ngx_str_t                   fp_ja3_hash;
+    ngx_str_t                   fp_ja4_data;
+    ngx_str_t                   fp_ja4_r;
+    ngx_str_t                   fp_ja4;
+    ngx_str_t                   fp_ja4_ro;
+    ngx_str_t                   fp_ja4_o;
+
+#endif
 };
 
 
